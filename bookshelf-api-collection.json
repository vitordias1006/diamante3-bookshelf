			"name": "Autores",
			"item": [
				{
					"name": "GET Listar todos os autores",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
									"pm.test('Resposta é JSON', () => pm.response.to.be.json);",
									"pm.test('Tem campo content (paginação)', () => {",
									"  const body = pm.response.json();",
									"  pm.expect(body).to.have.property('content');",
									"  pm.expect(body.content).to.be.an('array');",
									"});",
									"pm.test('Tem campos de paginação', () => {",
									"  const body = pm.response.json();",
									"  pm.expect(body).to.have.property('totalElements');",
									"  pm.expect(body).to.have.property('totalPages');",
									"  pm.expect(body).to.have.property('size');",
									"});",
									"pm.test('Autores têm campos obrigatórios', () => {",
									"  const autores = pm.response.json().content;",
									"  if (autores.length > 0) {",
									"    pm.expect(autores[0]).to.have.property('id');",
									"    pm.expect(autores[0]).to.have.property('nome');",
									"    pm.expect(autores[0]).to.have.property('totalLivros');",
									"  }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/autores?page=0&size=10&sort=nome&direction=asc",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
